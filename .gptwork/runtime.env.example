# =============================================================================
# GPTWork Runtime Configuration
# =============================================================================
# This file is a template. Copy it to runtime.env and customize.
#   cp .gptwork/runtime.env.example .gptwork/runtime.env
#
# Precedence: process.env > runtime.env > code defaults
# Values set in the system/process environment take highest priority.
# Values in this file fill in only when the env var is otherwise unset.
#
# This file is safe to commit. DO NOT commit the real runtime.env.
# =============================================================================

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# Production Profile
# ---------------------------------------------------------------------------
# For production deployments, the following checks apply:
#   - GPTWORK_CODEX_WORKER must be true
#   - GPTWORK_AGENT_ROLE_COMMANDS must configure verifier/reviewer commands
#     when those roles use local_command backend
#   - GPTWORK_CODEX_EXEC_TIMEOUT >= 3600 (production default)
#   - GPTWORK_DEFAULT_REPO should be set
#   - Release delivery check commands (GPTWORK_DELIVERY_RESULT_RECOVERY_COMMANDS)
#     should be configured for production hardening
# Run `gptwork init --production` to validate production profile.
# Run `gptwork doctor --local` for detailed diagnostics.
# ---------------------------------------------------------------------------
#
# ---------------------------------------------------------------------------

# GPTWORK_HOST=127.0.0.1
# GPTWORK_PORT=8787
# GPTWORK_WORKSPACE_ROOT=./data/workspaces/default
# GPTWORK_STATE_PATH=.gptwork/state.json
# GPTWORK_RUNTIME_ENV_FILE=.gptwork/runtime.env
# GPTWORK_TOOL_MODE=standard
# GPTWORK_WRITE_MODE=workspace
# GPTWORK_SHELL_MODE=full
# GPTWORK_SHELL_TRANSCRIPT=compact

# ---------------------------------------------------------------------------
# Codex worker

# Enable the Codex worker loop (default: false)
# Set to true for production to enable automatic task processing.
# Dev/local setups can leave this false and use manual task dispatch.
# GPTWORK_CODEX_WORKER=true

# Codex worker poll interval in milliseconds (default: 5000)
# GPTWORK_CODEX_WORKER_INTERVAL_MS=5000

# Codex worker max concurrent tasks (default: 4)
# GPTWORK_CODEX_WORKER_CONCURRENCY=4
# ---------------------------------------------------------------------------

# Codex execution timeout in seconds (default: 3600 = 40 minutes)
# GPTWORK_CODEX_EXEC_TIMEOUT=3600

# Additional arguments passed to `codex exec` (default: --yolo --skip-git-repo-check)
# GPTWORK_CODEX_EXEC_ARGS=--yolo --skip-git-repo-check

# Codex worker concurrency limit (default: 4; reserved for future use)
# GPTWORK_CODEX_CONCURRENCY=4

# ---------------------------------------------------------------------------
# Git remote tool defaults
# ---------------------------------------------------------------------------
# These defaults are used by git_remote_* tools when the corresponding
# argument is not provided by the caller.

# Default owner/repo (e.g. "9018/gpt-codex-workspace")
# GPTWORK_DEFAULT_REPO=

# Default branch name
# GPTWORK_DEFAULT_BRANCH=main

# Default local path to the Git checkout
# GPTWORK_DEFAULT_REPO_PATH=

# Default remote name
# GPTWORK_DEFAULT_REMOTE=origin

# ---------------------------------------------------------------------------
# Bark push notification (https://api.day.app)
# ---------------------------------------------------------------------------

# Enable or disable Bark notifications (true/false)
# GPTWORK_BARK_ENABLED=true

# Bark server URL (alternative to using API key)
# Example: https://api.day.app
# GPTWORK_BARK_URL=

# Bark API key (alternative to using full URL)
# GPTWORK_BARK_KEY=

# Default notification group
# GPTWORK_BARK_GROUP=gptwork

# Notification sound (e.g. "alarm", "anticipate", "bell", "california")
# Empty means use device default.
# GPTWORK_BARK_SOUND=

# Notification level: active, timeSensitive, passive
# GPTWORK_BARK_LEVEL=active

# Default icon URL for notifications
# GPTWORK_BARK_ICON_URL=

# Click/action URL for notifications
# GPTWORK_BARK_CLICK_URL=

# Badge count (number)
# GPTWORK_BARK_BADGE=

# ---------------------------------------------------------------------------
# Bark notification policy
# ---------------------------------------------------------------------------

# Global notification toggle (default: true)
# GPTWORK_BARK_NOTIFY_TASKS=true

# Suppress readonly tasks (default: false)
# GPTWORK_BARK_NOTIFY_READONLY=false

# Suppress internal tasks (default: false)
# GPTWORK_BARK_NOTIFY_INTERNAL=false

# Suppress test mode tasks (default: false)
# GPTWORK_BARK_NOTIFY_TESTS=false

# Suppress cancelled tasks (default: false)
# GPTWORK_BARK_NOTIFY_CANCELLED=false

# Notify on waiting_for_review (default: true)
# GPTWORK_BARK_NOTIFY_WAITING_REVIEW=true

# Notify on failures (default: true)
# GPTWORK_BARK_NOTIFY_FAILURES=true

# Notify on timeouts (default: true)
# GPTWORK_BARK_NOTIFY_TIMEOUTS=true

# Notify on completions (default: true)
# GPTWORK_BARK_NOTIFY_COMPLETED=true

# Notify on task creation (default: true)
# GPTWORK_BARK_NOTIFY_CREATED=true

# Notify on task started (default: false)
# GPTWORK_BARK_NOTIFY_STARTED=false

# Notify on lock-blocked states (default: false)
# GPTWORK_BARK_NOTIFY_LOCK_BLOCKED=false

# ---------------------------------------------------------------------------
# GitHub Issues sync (optional)
# ---------------------------------------------------------------------------

# Enable GitHub Issues sync (default: false; auto-detected if both REPO and TOKEN are set)
# GPTWORK_GITHUB_ENABLED=false

# GitHub repository for issue sync (owner/repo format)
# GPTWORK_GITHUB_REPO=

# GitHub personal access token
# GPTWORK_GITHUB_TOKEN=

# Max new GitHub Issues imported by each Codex worker tick (default: 20)
# GPTWORK_GITHUB_SYNC_LIMIT=20

# ---------------------------------------------------------------------------
# Shell and execution

# Delivery result recovery commands for production hardening (default: empty)
# Pipe-separated list of commands run to verify delivery results.
# Example: GPTWORK_DELIVERY_RESULT_RECOVERY_COMMANDS=npm --prefix backend run check:syntax||git diff --check
# GPTWORK_DELIVERY_RESULT_RECOVERY_COMMANDS=
# ---------------------------------------------------------------------------

# Shell command timeout in seconds (default: 60)
# GPTWORK_SHELL_TIMEOUT=60

# Maximum output bytes for shell commands (default: 200000)
# GPTWORK_MAX_OUTPUT_BYTES=200000

# Maximum output bytes for read file operations (default: 200000)
# GPTWORK_MAX_READ_BYTES=200000

# Maximum output bytes for shell output (default: 200000)
# GPTWORK_MAX_SHELL_OUTPUT_BYTES=200000

# ---------------------------------------------------------------------------
# Agent execution backends
# ---------------------------------------------------------------------------
# Integration mode
# ---------------------------------------------------------------------------

# Integration mode for task completion (default: auto)
#   auto    - ff-only merge when applicable
#   manual  - always requires manual integration
# GPTWORK_INTEGRATION_MODE=auto
# ---------------------------------------------------------------------------

# Default backend for assigned agent tasks. Supported values:
#   codex_exec     preserve the existing Codex CLI execution path
#   local_command  run a configured local shell command
#   null           test backend; returns a completed no-op result
# GPTWORK_AGENT_BACKEND=codex_exec

# Per-role backend overrides, comma-separated role=backend pairs.
# Example: builder keeps Codex, verifier runs a command, reviewer uses no-op.
# GPTWORK_AGENT_ROLE_BACKENDS=builder=codex_exec,verifier=local_command,reviewer=null

# Local command backend defaults. Role commands override the default command.
# GPTWORK_AGENT_LOCAL_COMMAND=npm --prefix backend test
# GPTWORK_AGENT_ROLE_COMMANDS=verifier=npm --prefix backend test||reviewer=node scripts/review.mjs
# GPTWORK_AGENT_COMMAND_TIMEOUT=60
# GPTWORK_AGENT_COMMAND_FIRST_OUTPUT_TIMEOUT=0
# GPTWORK_AGENT_COMMAND_NO_PROGRESS_TIMEOUT=0

# ---------------------------------------------------------------------------
# Other
# ---------------------------------------------------------------------------
# Context index / Vector store
# ---------------------------------------------------------------------------

# Context vector store backend (default: auto)
#   auto    - auto-detect zvec binary
#   none    - disable vector indexing
# GPTWORK_CONTEXT_VECTOR_STORE=auto
# ---------------------------------------------------------------------------

# Codex user home path (default: /home/a9017)
# GPTWORK_CODEX_HOME=/home/a9017
# GPTWORK_ENABLE_TASK_WORKTREES=true

# Python command (default: python3 on Linux/Mac, python on Windows)
# GPTWORK_PYTHON=python3

# Log file path (empty = no persistent logging)
# GPTWORK_LOG_PATH=

# Require authentication for MCP connections (default: true)
# GPTWORK_REQUIRE_AUTH=true

# Comma-separated list of API tokens
# GPTWORK_TOKENS=dev-token,test

# SSH SOCKS proxy host:port for SSH workspace connections
# GPTWORK_SSH_SOCKS_PROXY=10.0.1.105:20177

# Token contexts JSON mapping (for multi-user scenarios)
# GPTWORK_TOKEN_CONTEXTS=
