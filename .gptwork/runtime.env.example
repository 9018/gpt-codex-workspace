# GPTWork workspace-local runtime environment
# Copy this file to <workspace>/.gptwork/runtime.env and fill in your values.
# process.env always takes priority over values in this file.
#
# Example Bark notification settings:
# GPTWORK_BARK_ENABLED=true
# GPTWORK_BARK_KEY=your_bark_key_here
# GPTWORK_BARK_GROUP=gptwork
# GPTWORK_BARK_SOUND=default
# GPTWORK_BARK_LEVEL=active
