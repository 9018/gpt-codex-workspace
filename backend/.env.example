GPTWORK_HOST=0.0.0.0
GPTWORK_PORT=8787
GPTWORK_STATE_PATH=/home/a9017/mcp/gpt-codex-workspace/data/state.json
GPTWORK_WORKSPACE_ROOT=/home/a9017/mcp/gpt-codex-workspace/workspaces/default
GPTWORK_TOKENS=dev-token,test
GPTWORK_REQUIRE_AUTH=true
GPTWORK_SHELL_TIMEOUT=60
GPTWORK_MAX_READ_BYTES=200000
GPTWORK_MAX_SHELL_OUTPUT_BYTES=200000

# Token contexts: JSON mapping tokens to user/project/workspace/scopes
# GPTWORK_TOKEN_CONTEXTS={"dev-token":{"user_id":"user_dev","user_name":"Developer","team_id":"team_default","project_ids":["default"],"workspace_ids":["*"],"scopes":["project:read","project:admin","workspace:read","workspace:write","files:upload","files:download","shell:exec","ssh:use","browser:use","task:create","task:update","task:assign_codex","audit:read"]}}

# GitHub Issues sync (optional) - mirrors tasks and coordination requests to GitHub Issues
# Allows ChatGPT to see task status via GitHub without needing public MCP endpoint
# GPTWORK_GITHUB_REPO=owner/repo
# GPTWORK_GITHUB_TOKEN=ghp_xxxxxxxxxxxx
