# =============================================================================
# GPTWork Development Environment Template
# =============================================================================
# This file is a development reference showing example GPTWORK_* configuration.
# The actual deployment uses .gptwork/runtime.env at the workspace root.
# Values here reflect a sample production deployment on 10.0.1.103.
# =============================================================================

GPTWORK_HOST=0.0.0.0
GPTWORK_PORT=8787
GPTWORK_STATE_PATH=/home/a9017/mcp/workspace/.gptwork/state.json
GPTWORK_WORKSPACE_ROOT=/home/a9017/mcp/workspace
GPTWORK_TOKENS=dev-token,test
GPTWORK_REQUIRE_AUTH=true
GPTWORK_SHELL_TIMEOUT=60
GPTWORK_MAX_READ_BYTES=200000
GPTWORK_MAX_SHELL_OUTPUT_BYTES=200000
GPTWORK_CODEX_HOME=/home/a9017
GPTWORK_CODEX_EXEC_ARGS=--yolo --skip-git-repo-check
GPTWORK_PYTHON=python3
GPTWORK_SSH_SOCKS_PROXY=10.0.1.105:20177

# Workspace safety guard modes
# GPTWORK_SHELL_MODE=full        # off|safe|full (default: full)
# GPTWORK_WRITE_MODE=workspace   # off|handoff|workspace (default: workspace)
# GPTWORK_SHELL_TRANSCRIPT=compact # compact|full (default: compact)
# safe shell mode restricts commands to read-only safe operations
# handoff write mode prevents workspace mutations
GPTWORK_DEFAULT_REPO=9018/gpt-codex-workspace
GPTWORK_DEFAULT_BRANCH=main
GPTWORK_DEFAULT_REPO_PATH=/home/a9017/mcp/workspace/gpt-codex-workspace
GPTWORK_DEFAULT_REMOTE=origin

# Agent execution backends
# GPTWORK_AGENT_BACKEND=codex_exec
# GPTWORK_AGENT_ROLE_BACKENDS=builder=codex_exec,verifier=local_command,reviewer=null
# GPTWORK_AGENT_LOCAL_COMMAND=npm --prefix backend test
# GPTWORK_AGENT_ROLE_COMMANDS=verifier=npm --prefix backend test||reviewer=node scripts/review.mjs
# GPTWORK_AGENT_COMMAND_TIMEOUT=60

# Token contexts: JSON mapping tokens to user/project/workspace/scopes
# GPTWORK_TOKEN_CONTEXTS={"dev-token":{"user_id":"user_dev","user_name":"Developer","team_id":"team_default","project_ids":["default"],"workspace_ids":["*"],"scopes":["project:read","project:admin","workspace:read","workspace:write","files:upload","files:download","shell:exec","ssh:use","browser:use","task:create","task:update","task:assign_codex","audit:read"]}}

# GitHub Issues sync (optional) - mirrors tasks and coordination requests to GitHub Issues
# Allows ChatGPT to see task status via GitHub without needing public MCP endpoint
# GPTWORK_GITHUB_REPO=owner/repo
# GPTWORK_GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Bark push notification (https://api.day.app)
# GPTWORK_BARK_KEY=your_bark_key_here

# Bark push notification settings
# GPTWORK_BARK_ENABLED=true
# GPTWORK_BARK_KEY=your_bark_key_here
# GPTWORK_BARK_URL=https://api.day.app
# GPTWORK_BARK_GROUP=gptwork
# GPTWORK_BARK_SOUND=
# GPTWORK_BARK_LEVEL=active
# GPTWORK_BARK_ICON_URL=
# GPTWORK_BARK_CLICK_URL=
# GPTWORK_BARK_BADGE=

# Workspace-local runtime env (default: <workspace>/.gptwork/runtime.env)
# GPTWORK_RUNTIME_ENV_FILE=.gptwork/runtime.env
